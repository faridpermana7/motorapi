{
  "version": "0.2.0",
  "configurations": [
      {
        "name": "Debug FastAPI (no reload)",
        "type": "debugpy",
        "request": "launch",
        "module": "uvicorn",
        "args": [
          "main:app",
          "--host",
          "127.0.0.1",
          "--port",
          "9999"
        ],
        "envFile": "${workspaceFolder}/.env",
        "subProcess": true,
        "justMyCode": true,
        "jinja": true
    }
  ]
}